# VibeRadar Flutter App Environment
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Or run: ./scripts/setup.sh

# OpenAI — powers the AI Copilot chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Spotify — powers artist catalogue lookup in the Artists screen
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Firebase keys are hardcoded in firebase_options.dart (safe for client-side).
# Cloud Function secrets (Spotify, YouTube, Apple Music) are stored in
# Firebase Secret Manager — they deploy with `firebase deploy` and don't
# need to be in this file.
